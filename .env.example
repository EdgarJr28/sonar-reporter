# Copiá este archivo a ".env" (sin ".example") y ajustá los valores.
# app.py carga automáticamente ".env" al arrancar (python-dotenv). Ningún
# valor es obligatorio: si falta una variable, se usa el default indicado.

# --- SonarQube ---
SONARQUBE_HOST=http://localhost:9000
# Opcional: proyecto que se muestra al entrar a "/". Dejalo vacío (o
# comentado) para que "/" muestre siempre un selector con todos los
# proyectos disponibles (/select-project) — recomendado salvo que sepas que
# ese proyecto siempre va a existir en esta instancia de SonarQube.
DEFAULT_PROJECT_KEY=

# --- Servidor Flask ---
FLASK_PORT=5000
FLASK_DEBUG=true

# --- Sesión / login ---
# Si se deja vacío, se genera una clave sola y se guarda en .flask_secret_key
# (persiste entre reinicios). Definila acá solo si necesitás controlarla vos
# mismo (por ejemplo en Docker/producción con múltiples contenedores).
FLASK_SECRET_KEY=

# --- Cache y límites ---
CACHE_TTL_SECONDS=60
PDF_MAX_ISSUES=300
HISTORY_MAX_POINTS=30
ISSUES_PAGE_SIZE=500
REQUEST_TIMEOUT=60
